{
  "name": "btreemap",
  "version": "2.1.1",
  "description": "A B-tree based map with support for ordered iteration, range queries, and non-unique keys",
  "files": [
    "dist"
  ],
  "main": "./dist/btreemap.js",
  "scripts": {
    "test": "tsc && node --test --experimental-test-coverage ./test/test.js",
    "coverage": "tsc && node --test --experimental-test-coverage --test-reporter=lcov ./test/test.js > coverage.lcov",
    "report-coverage": "codecov",
    "ci": "npm run coverage && npm run report-coverage",
    "release": "tsc && npm login && npm publish"
  },
  "keywords": [
    "btree",
    "b-tree",
    "map",
    "sorted",
    "ordered",
    "index",
    "range",
    "iterator",
    "data-structure",
    "typescript"
  ],
  "author": "James BonTempo",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/jamesbontempo/btreemap.git"
  },
  "devDependencies": {
    "@tsconfig/node23": "^23.0.4",
    "@types/node": "^25.5.2",
    "codecov": "^3.8.2",
    "typescript": "^5.9.3"
  }
}
